  20 def serialize_json(data: dict) -> str:                                                      
  21     """Serialize a Python dict to JSON string using stdlib."""                              
  22     return ujson.dumps(data, indent=2)                                                      
  23                                                                                             
  24 def deserialize_json(text: str) -> dict:                                                    
  25     """Deserialize a JSON string to Python dict using stdlib."""                            
  26     return ujson.loads(text)                                                                
  27                                                                                             
  28 def serialize_list_json(items: list) -> str:                                                
  29     """Serialize a list to JSON."""                                                         
  30     return ujson.dumps(items)                                                               
